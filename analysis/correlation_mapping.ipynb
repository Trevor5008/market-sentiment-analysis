        "    print(f\"  Spearman rho = {rho_h2:.4f}  (negative = supported)\")\n",
        "    print(f\"  p-value      = {p_h2:.4f}\")\n",
        "    print(f\"  Effect size  = |rho| = {abs(rho_h2):.3f}\")\n",
        "    print(f\"  Verdict:  {verdict_h2}\")\n",
